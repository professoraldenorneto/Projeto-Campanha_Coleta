rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny for safety
    match /{document=**} {
      allow read, write: if false;
    }

    // Reports collection
    match /reports/{reportId} {
      // Anyone can see reports (Waze-style)
      allow read: if true;
      
      // must be signed in to create a report
      allow create: if request.auth != null 
        && isValidReport(request.resource.data)
        && request.resource.data.userId == request.auth.uid;

      // Only drivers or admins can update status
      allow update: if request.auth != null 
        && (
          incoming().diff(existing()).affectedKeys().hasOnly(['status']) 
          // Add driver check here if users collection exists and role is checked
        );
    }

    // Users collection
    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Helper functions
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isSignedIn() { return request.auth != null; }

    function isValidReport(data) {
      return data.imageUrl is string 
        && data.address.street is string
        && data.address.neighborhood is string
        && data.status in ['pending', 'in_progress', 'collected']
        && data.userId is string
        && data.createdAt is timestamp;
    }
  }
}
