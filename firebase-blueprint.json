{
  "entities": {
    "Report": {
      "title": "Report",
      "description": "A garbage disposal report",
      "type": "object",
      "properties": {
        "imageUrl": {
          "type": "string",
          "description": "URL of the uploaded image"
        },
        "location": {
          "type": "object",
          "properties": {
            "lat": { "type": "number" },
            "lng": { "type": "number" }
          },
          "required": ["lat", "lng"]
        },
        "address": {
          "type": "object",
          "properties": {
            "street": { "type": "string" },
            "number": { "type": "string" },
            "neighborhood": { "type": "string" },
            "complement": { "type": "string" }
          },
          "required": ["street", "neighborhood"]
        },
        "status": {
          "type": "string",
          "enum": ["pending", "in_progress", "collected"],
          "description": "Current status of the report"
        },
        "userId": {
          "type": "string",
          "description": "ID of the user who reported"
        },
        "description": {
          "type": "string",
          "description": "Additional details"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": ["imageUrl", "location", "status", "userId", "createdAt"]
    },
    "User": {
      "title": "User",
      "description": "App user profile",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "name": { "type": "string" },
        "role": {
          "type": "string",
          "enum": ["citizen", "driver", "admin"]
        }
      },
      "required": ["email", "role"]
    }
  },
  "firestore": {
    "reports": {
      "schema": "Report",
      "description": "Collection of waste reports"
    },
    "users": {
      "schema": "User",
      "description": "User profiles and roles"
    }
  }
}
